{
  "name": "@slothbox/api-gateway",
  "version": "0.1.0-alpha.1",
  "private": true,
  "type": "module",
  "description": "SlothBox API gateway — share lifecycle, rate limiting, audit chain, WebSocket progress.",
  "license": "MIT",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "echo 'api-gateway uses tsc strict for static checks; eslint config to be added in v0.5' && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.0.5",
    "@hono/zod-validator": "^0.4.1",
    "@slothbox/db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.10",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.8",
    "nats": "^2.28.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.4",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "pino-pretty": "^11.3.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
