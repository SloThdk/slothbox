    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.1.4",
    "postcss": "^8.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0-beta.4",
    "typescript": "^5.6.3"
