# SlothBox web frontend — local env overrides.
#
# The canonical example lives at the monorepo root (`.env.example`). This file
# only documents the NEXT_PUBLIC_* variables the web app actually reads at
# build time — the others (DATABASE_URL, AUTH_SECRET, etc.) belong on the
# gateway / ingest / reaper services.

NEXT_PUBLIC_API_URL=http://localhost:3022
NEXT_PUBLIC_WS_URL=ws://localhost:3022
NEXT_PUBLIC_INGEST_URL=http://localhost:3023
NEXT_PUBLIC_PUBLIC_URL=http://localhost:3021
NEXT_PUBLIC_MAX_FILE_SIZE_MB=4096
