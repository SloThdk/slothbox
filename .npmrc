# pnpm configuration
#
# node-linker=hoisted gives us npm-style flat node_modules. Reasons:
#   1. libsodium-wrappers v0.7.16 has a broken ESM build with a relative
#      .mjs import that pnpm's symlinks can't resolve (issue #308).
#   2. Next 15 + styled-jsx need `client-only` and `server-only` reachable
#      from the next-server compiled bundle, which pnpm's strict layout
#      doesn't guarantee for transitive deps.
#   3. The .NET ingest service Dockerfile depends on `pnpm exec tsup` finding
#      its binary — strict layout breaks that under filter mode.
# This costs a bit of disk for the repeated package copies, but the
# whole-stack reliability win is decisive for v0.1.
node-linker=hoisted

# Strict peer-dep handling without breaking install on optional peer drift
strict-peer-dependencies=false
auto-install-peers=true

# Reproducibility
prefer-frozen-lockfile=true

# Node version pin
engine-strict=true
