# pnpm configuration
# libsodium-wrappers-sumo has an internal dynamic import that breaks under
# pnpm's default symlink layout. Hoisting it makes the relative import resolve.
public-hoist-pattern[]=*libsodium*
public-hoist-pattern[]=@types/libsodium*

# Strict peer-dep handling without breaking install on optional peer drift
strict-peer-dependencies=false
auto-install-peers=true

# Reproducibility
shamefully-hoist=false
prefer-frozen-lockfile=true

# Node version pin
engine-strict=true
