# SlothBox — Caddy reverse proxy + TLS edge
#
# This file controls public ingress for the production deployment.
# Key responsibilities:
#   1. Terminate TLS on slothbox.philipsloth.com via Let's Encrypt (HTTP-01).
#   2. Reverse-proxy paths to internal services on the docker network.
#   3. Set every browser security header EXCEPT Content-Security-Policy.
#      CSP must include a per-request nonce, which only the Next.js
#      middleware can mint — see apps/web/src/middleware.ts.
#   4. Strip the Server header so we don't leak Caddy's version.
#   5. Cap request bodies per-route (1 MB by default, 12 MB for /chunk/*).
#
# Local development uses :80 and skips TLS — no Caddyfile-level toggle is
# needed because the dev compose file overrides DOMAIN to "localhost"
# which makes Caddy bind plaintext only.

{
	# Maintainer's real, monitored inbox — Let's Encrypt mails this address
	# when a cert is approaching expiry without a renewal, when ACME rate
	# limits are hit, and on policy changes (e.g. CT log expectations). This
	# must be a working address; using a non-existent contact silently
	# breaks the warning loop and the first sign of trouble becomes a hard
	# outage 90 days later.
	email philipsloth1@gmail.com

	# HTTP/3 + HTTP/2 + HTTP/1.1. h3 needs UDP/443 open in the cloud
	# provider's network firewall — verify before deploy. UDP/443 is an
	# explicit firewall rule because most providers default-deny UDP.
	servers {
		protocols h1 h2 h3
	}

	# Persistent ACME storage on the named volume so cert state survives
	# `docker compose down`.
	storage file_system /data
}

# ─── Production HTTPS ────────────────────────────────────────────────
slothbox.philipsloth.com {
	# Caddy auto-issues + auto-renews. ACME HTTP-01 challenge requires
	# port 80 reachable from the public internet — the cloud provider's
	# firewall rule "HTTP (Caddy ACME)" allows this. Without it, cert
	# renewal silently fails 60 days in and the site goes dark on day 90.

	# ── Liveness ─────────────────────────────────────────────────
	handle /healthz {
		respond "ok" 200
	}

	# ── API gateway (HTTP) ──────────────────────────────────────
	# All /api/* traffic is REST. Hono on :3022.
	handle /api/* {
		reverse_proxy api-gateway:3022 {
			# Pass real client IP so the gateway's rate-limiter keys
			# correctly. CF-Connecting-IP is set IF the request ever
			# reverses through Cloudflare; otherwise X-Forwarded-For
			# is the canonical source.
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
	}

	# ── API gateway (WebSocket) ────────────────────────────────
	# Progress channel for long-running uploads. Caddy auto-detects
	# WebSocket upgrade and switches to bidirectional pipe — but we
	# explicitly carry the Upgrade/Connection headers and disable
	# response buffering so frames don't pool up at the edge.
	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle /ws/* {
		reverse_proxy @websocket api-gateway:3022 {
			flush_interval -1
		}
		# Non-WS clients hitting /ws (curl, mistakes) should see a
		# clean 426 Upgrade Required, not a 502.
		reverse_proxy api-gateway:3022 {
			flush_interval -1
		}
	}

	# ── Ingest service (chunked uploads) ───────────────────────
	# .NET 8 on :3023. Streams 0-5 GB bodies — disable Caddy buffering
	# so memory pressure on the edge stays bounded regardless of upload
	# size.
	handle /chunk/* {
		reverse_proxy ingest:3023 {
			flush_interval -1
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# ── Receipt service (court-admissible delivery proofs) ────
	# .NET 8 on :3024. Most v0.1 endpoints return 501 by design.
	handle /receipt/* {
		reverse_proxy receipt:3024
	}

	# ── Frontend (everything else) ────────────────────────────
	handle {
		reverse_proxy web:3021 {
			# Next standalone server reads X-Forwarded-* for
			# absolute-URL generation in metadata + OG tags.
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
	}

	# ── Security headers ─────────────────────────────────────
	# Note: CSP is INTENTIONALLY OMITTED here. The Next.js middleware
	# at apps/web/src/middleware.ts mints a per-request nonce and emits
	# the full CSP including 'nonce-...' + 'strict-dynamic'. Setting
	# CSP at both layers would emit two headers and confuse browsers.
	header {
		# 2-year HSTS with subdomains + preload. Submission to the
		# preload list is a manual step at hstspreload.org once we
		# have stable subdomain coverage.
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		# Permissions-Policy: deny every sensor + media-routing capability
		# the app doesn't use. Each `feature=()` denies even same-origin
		# access; if the app ever legitimately needs one of these we'll
		# allowlist it explicitly with `feature=(self)`. Includes the
		# legacy floc opt-out (`interest-cohort`) and the newer ad-tracking
		# / sensor / media-stream APIs an encrypted-file-transfer page has
		# no reason to invoke.
		Permissions-Policy "accelerometer=(), ambient-light-sensor=(), autoplay=(), battery=(), camera=(), display-capture=(), document-domain=(), encrypted-media=(), execution-while-not-rendered=(), execution-while-out-of-viewport=(), fullscreen=(self), gamepad=(), geolocation=(), gyroscope=(), hid=(), idle-detection=(), interest-cohort=(), keyboard-map=(), magnetometer=(), microphone=(), midi=(), navigation-override=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), screen-wake-lock=(), serial=(), sync-xhr=(), usb=(), web-share=(self), xr-spatial-tracking=()"
		# Block Adobe Flash / Reader cross-domain XML lookups. Legacy
		# attack surface in modern terms; setting `none` here is one of
		# the cheapest hardening wins available.
		X-Permitted-Cross-Domain-Policies "none"
		Cross-Origin-Embedder-Policy "require-corp"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		# Strip server identification.
		-Server
		# Remove the legacy header that exposes implementation.
		-X-Powered-By
	}

	# ── Compression ──────────────────────────────────────────
	encode zstd gzip

	# ── Body size limits ─────────────────────────────────────
	# Per-route caps. Anything outside the explicitly listed routes
	# is bounded to 1 MB which is plenty for /api/* JSON payloads.
	#
	# /chunk/* cap is 12 MB — matches the .NET ingest service's
	# Kestrel MaxChunkBytes of 10 MB plus ~2 MB slack for HTTP
	# headers and chunked-transfer overhead. Earlier 5 GB ceiling
	# (closed by the 2026-05-08 abuse-hardening pass) let an
	# attacker stream 5 GB junk per chunk through Caddy before
	# ingest 413'd it on the wire — a 500x bandwidth amplification
	# vs the 10 MB Kestrel actually accepts. Aligning the two caps
	# rejects oversized chunks AT the edge before the bytes reach
	# the application layer.
	request_body /chunk/* {
		max_size 12MB
	}
	request_body /api/* {
		max_size 1MB
	}
	request_body / {
		max_size 1MB
	}

	# ── Structured logging ───────────────────────────────────
	log {
		output stdout
		format json
		# Don't log every healthcheck poll — they're noise and they
		# would dominate Loki's volume in steady state.
		level INFO
	}
}

# ─── Local dev — same routing rules, plain HTTP, no TLS ──────────────
# When developers run `docker compose up` on their laptop, they hit the
# stack via http://localhost/. Without this block Caddy would 301 every
# such request to https://slothbox.philipsloth.com (per the IP-fallback
# rule below), which is the opposite of useful for local testing.
http://localhost {
	handle /healthz {
		respond "ok" 200
	}
	handle /api/* {
		reverse_proxy api-gateway:3022
	}
	@websocket_local {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle /ws/* {
		reverse_proxy @websocket_local api-gateway:3022 {
			flush_interval -1
		}
		reverse_proxy api-gateway:3022 {
			flush_interval -1
		}
	}
	handle /chunk/* {
		reverse_proxy ingest:3023 {
			flush_interval -1
		}
	}
	handle /receipt/* {
		reverse_proxy receipt:3024
	}
	handle {
		reverse_proxy web:3021
	}
	encode zstd gzip
	# No HSTS / COOP / CSP here — those are production-only. Local dev
	# uses Next's middleware-injected CSP straight through.
}

# ─── HTTP -> HTTPS redirect for production IP / wrong-host requests ──
# Anyone hitting the production VM's bare IPv4 directly, or any other
# host header arriving on plain :80 (other than localhost handled
# above), gets bounced to the canonical HTTPS domain. Also keeps :80
# open for the Let's Encrypt HTTP-01 challenge.
:80 {
	redir https://slothbox.philipsloth.com{uri} permanent
}
