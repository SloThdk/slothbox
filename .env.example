# SlothBox — Environment Variables (Example)
# Copy to .env and fill in real values for local development.
# .env is gitignored. NEVER commit real values.

# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PUBLIC_URL=http://localhost:3021
APP_NAME=SlothBox

# ─── Frontend (Next.js) ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3022
NEXT_PUBLIC_WS_URL=ws://localhost:3022
NEXT_PUBLIC_INGEST_URL=http://localhost:3023
NEXT_PUBLIC_MAX_FILE_SIZE_MB=4096

# ─── API Gateway (Hono) ────────────────────────────────────────
API_PORT=3022
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:3021

# ─── Ingest Service (.NET) ─────────────────────────────────────
INGEST_PORT=3023
INGEST_CHUNK_SIZE_BYTES=5242880
INGEST_MAX_PARALLEL_CHUNKS=4

# ─── Receipt Service (.NET) ────────────────────────────────────
RECEIPT_PORT=3024
RECEIPT_TSA_URL=https://freetsa.org/tsr
RECEIPT_TSA_TIMEOUT_SECONDS=30

# ─── Postgres ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=slothbox
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_DEV_ONLY
POSTGRES_DB=slothbox
DATABASE_URL=postgresql://slothbox:CHANGE_ME_LOCAL_DEV_ONLY@localhost:5433/slothbox

# ─── MinIO (S3-compatible object storage) ──────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=slothbox-local
MINIO_SECRET_KEY=CHANGE_ME_LOCAL_DEV_ONLY_MIN_8_CHARS
MINIO_BUCKET=slothbox-blobs
MINIO_REGION=eu-central-1
MINIO_USE_SSL=false

# ─── Valkey (Redis fork) ───────────────────────────────────────
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=
REDIS_URL=redis://localhost:6379

# ─── NATS (pub/sub) ────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ─── Auth (Lucia) — v0.5+ ──────────────────────────────────────
AUTH_SECRET=CHANGE_ME_GENERATE_VIA_OPENSSL_RAND_HEX_32
AUTH_SESSION_COOKIE_NAME=slothbox_session
AUTH_SESSION_TTL_SECONDS=2592000

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_ANONYMOUS_PER_MINUTE=10
RATE_LIMIT_ANONYMOUS_PER_DAY=100
RATE_LIMIT_AUTHED_PER_MINUTE=60

# ─── Share Defaults ────────────────────────────────────────────
SHARE_DEFAULT_EXPIRY_HOURS=168
SHARE_MAX_EXPIRY_HOURS=720
SHARE_MAX_DOWNLOADS=100

# ─── Reaper Daemon ─────────────────────────────────────────────
REAPER_INTERVAL_SECONDS=60
REAPER_BATCH_SIZE=100

# ─── Cryptography ──────────────────────────────────────────────
# Argon2id parameters — production defaults
ARGON2_MEMORY_KB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# ─── Observability ─────────────────────────────────────────────
LOG_LEVEL=info
PROMETHEUS_ENABLED=true
LOKI_URL=http://localhost:3100

# ─── Feature Flags ─────────────────────────────────────────────
FEATURE_BURN_AFTER_READ=true
FEATURE_PASSWORD_PROTECTED_SHARES=true
FEATURE_RFC3161_RECEIPTS=false
FEATURE_PER_RECIPIENT_ENCRYPTION=false
FEATURE_WEBRTC_P2P=false
FEATURE_MITID_AUTH=false
