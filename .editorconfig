# Top-most EditorConfig file
root = true

# Universal defaults
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# Markdown — keep trailing whitespace (line breaks)
[*.md]
trim_trailing_whitespace = false

# Go uses tabs
[*.go]
indent_style = tab
indent_size = 4

# C# / .NET
[*.{cs,csproj,sln}]
indent_size = 4

# Makefiles must use tabs
[Makefile]
indent_style = tab

# Windows scripts
[*.{bat,cmd,ps1}]
end_of_line = crlf
